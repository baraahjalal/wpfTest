                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#080D1C" Offset="0"/>
                            <GradientStop Color="#0C1325" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Subtle bottom glow -->
                <Ellipse Width="400" Height="200"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,-100"
                         Opacity="0.12">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#00D4FF" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Close button -->
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,20,0"
                        Width="32" Height="32"
                        Foreground="#4A7FA0"
                        FontSize="14"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="6"
                                    Background="Transparent"
                                    Width="32" Height="32">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A2A40"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Form content -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="320">

                    <!-- Logo badge -->
                    <Border Width="60" Height="60"
                            CornerRadius="14"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0E2C4A" Offset="0"/>
                                <GradientStop Color="#082038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#00D4FF" BlurRadius="18"
                                              ShadowDepth="0" Opacity="0.45"/>
                        </Border.Effect>
                        <TextBlock Text="⬡"
                                   FontSize="32"
                                   Foreground="#00D4FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Heading -->
                    <TextBlock Text="Welcome Back"
                               Foreground="#E8F4FF"
                               FontFamily="Segoe UI Light"
                               FontSize="26"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sign in to your account"
                               Foreground="#3D6080"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,36"/>

                    <!-- Username -->
                    <TextBlock Text="USERNAME"
                               Foreground="#3D6080"
                               FontFamily="Consolas"
                               FontSize="10"
                               FontWeight="Bold"
                               LetterSpacing="2"
                               Margin="0,0,0,6"/>
                    <Grid>
                        <TextBox x:Name="TxtUsername"
                                 Style="{StaticResource TechInput}"
                                 Padding="40,10,12,10"/>
                        <!-- icon -->
                        <TextBlock Text="👤"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Opacity="0.5"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Password -->
                    <TextBlock Text="PASSWORD"
                               Foreground="#3D6080"
                               FontFamily="Consolas"
                               FontSize="10"
                               FontWeight="Bold"
                               LetterSpacing="2"
                               Margin="0,18,0,6"/>
                    <Grid>
                        <PasswordBox x:Name="PbxPassword"
                                     Style="{StaticResource TechPassword}"
                                     Padding="40,10,12,10"/>
                        <TextBlock Text="🔒"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Opacity="0.5"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Remember me + Forgot -->
                    <Grid Margin="0,14,0,0">
                        <CheckBox x:Name="ChkRemember"
                                  Content="Remember me"
                                  Style="{StaticResource TechCheck}"
                                  HorizontalAlignment="Left"/>
                        <Button Content="Forgot password?"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="BtnForgot_Click"/>
                    </Grid>

                    <!-- Error message area -->
                    <Border x:Name="PanelError"
                            Background="#1A0A0A"
                            BorderBrush="#FF3B3B"
                            BorderThickness="0,0,0,2"
                            CornerRadius="8,8,0,0"
                            Padding="12,8"
                            Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " Foreground="#FF5555" FontSize="13"/>
                            <TextBlock x:Name="TblError"
                                       Text="Invalid credentials. Try again."
                                       Foreground="#FF7777"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Sign-in button -->
                    <Button Content="SIGN IN"
                            Style="{StaticResource GlowButton}"
                            Margin="0,24,0,0"
                            Click="BtnLogin_Click">
                        <Button.Effect>
                            <DropShadowEffect Color="#00D4FF" BlurRadius="20"
                                              ShadowDepth="0" Opacity="0.4"/>
                        </Button.Effect>
                    </Button>

                    <!-- Divider -->
                    <Grid Margin="0,28,0,20">
                        <Rectangle Height="1" Fill="#0E2A40" VerticalAlignment="Center"/>
                        <TextBlock Text="SECURE ACCESS"
                                   Background="#0C1325"
                                   Foreground="#1E3A5F"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Padding="10,0"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Lock-out countdown (hidden by default) -->
                    <Border x:Name="PanelLockout"
                            Background="#0F0A20"
                            BorderBrush="#7B00FF"
                            BorderThickness="0,0,0,2"
                            CornerRadius="8,8,0,0"
                            Padding="12,8"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔐  Account locked — try again in "
                                       Foreground="#AA77FF"
                                       FontFamily="Segoe UI"
                                       FontSize="12"/>
                            <TextBlock x:Name="TblCountdown"
                                       Text="30s"
                                       Foreground="#CC99FF"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Footer -->
                    <TextBlock HorizontalAlignment="Center"
                               Margin="0,20,0,0">
                        <Run Text="v2.0  ·  InventoryDBv3  ·  "
                             Foreground="#1E3A5F"
                             FontFamily="Consolas"
                             FontSize="10"/>
                        <Run Text="© 2025 IMS"
                             Foreground="#1E3A5F"
                             FontFamily="Consolas"
                             FontSize="10"/>
                    </TextBlock>

                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>
