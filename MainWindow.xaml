<Window x:Class="testt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory Management System"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#08111F">

    <Grid>

        <!-- Background -->

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#08111F" Offset="0"/>
                <GradientStop Color="#101C35" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Glow Effects -->

        <Ellipse Width="450"
                 Height="450"
                 Fill="#2200D4FF"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-120,0,0"/>

        <Ellipse Width="350"
                 Height="350"
                 Fill="#1800D4FF"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-100,-100"/>

        <!-- Main Card -->

        <Border Width="1000"
                Height="550"
                CornerRadius="25"
                Background="#151D30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="25"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side -->

                <Border Background="#11192B"
                        CornerRadius="25,0,0,25">

                    <StackPanel VerticalAlignment="Center"
                                Margin="50">

                        <TextBlock Text="🖥"
                                   FontSize="90"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="TECH INVENTORY"
                                   Foreground="White"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"/>

                        <TextBlock Text="Management System"
                                   Foreground="#00D4FF"
                                   FontSize="20"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Track • Manage • Secure"
                                   Foreground="#B7C3DD"
                                   FontSize="15"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,30"/>

                        <Border Background="#1E2942"
                                CornerRadius="10"
                                Padding="15"
                                Margin="0,5">

                            <TextBlock Text="✓ Device Tracking"
                                       Foreground="White"/>
                        </Border>

                        <Border Background="#1E2942"
                                CornerRadius="10"
                                Padding="15"
                                Margin="0,5">

                            <TextBlock Text="✓ Hardware Inventory"
                                       Foreground="White"/>
                        </Border>

                        <Border Background="#1E2942"
                                CornerRadius="10"
                                Padding="15"
                                Margin="0,5">

                            <TextBlock Text="✓ Asset Monitoring"
                                       Foreground="White"/>
                        </Border>

                        <Border Background="#1E2942"
                                CornerRadius="10"
                                Padding="15"
                                Margin="0,5">

                            <TextBlock Text="✓ Smart Reporting"
                                       Foreground="White"/>
                        </Border>

                    </StackPanel>

                </Border>

                <!-- Right Side -->

                <Grid Grid.Column="1">

                    <StackPanel Width="320"
                                VerticalAlignment="Center">

                        <TextBlock Text="Welcome Back"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Please sign in to your account"
                                   Foreground="#9BA8C4"
                                   Margin="0,10,0,30"/>

                        <TextBlock Text="Username"
                                   Foreground="White"/>

                        <ComboBox Height="45"
                                  Margin="0,8,0,15"
                                  FontSize="14"/>

                        <TextBlock Text="Password"
                                   Foreground="White"/>

                        <PasswordBox Height="45"
                                     Margin="0,8,0,20"/>

                        <Button Content="SIGN IN"
                                Height="50"
                                FontWeight="Bold"
                                Foreground="White"
                                BorderThickness="0">

                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">
                                    <GradientStop Color="#00D4FF"/>
                                    <GradientStop Color="#0078FF"
                                                  Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>

                        </Button>

                        <TextBlock Text="Locked. Try again in 30 seconds."
                                   Foreground="#FF7A7A"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"/>

                    </StackPanel>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>

